# Copy to .env and fill in. Used by sync/sync.js (NOT by the web app).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-secret-key         # Supabase > Project Settings > API Keys > Secret key (keep secret!)
FOOTBALL_DATA_TOKEN=your-football-data-token # free token from https://www.football-data.org/client/register
